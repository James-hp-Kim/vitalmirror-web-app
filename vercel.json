{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/phone",
      "dest": "/index.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "handle": "filesystem"
    }
  ],
  "functions": {
    "api/index.py": {
      "excludeFiles": "{data/**,logs/**,tools/**,__pycache__/**,**/*.pyc,models/**}"
    }
  }
}
